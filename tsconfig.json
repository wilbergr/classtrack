{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true
  },
  // test/*.test.ts run on Node's built-in runner with TS type-stripping and use
  // explicit `.ts` import specifiers (which Node requires but tsc rejects without
  // allowImportingTsExtensions). They are validated by `npm test`, not this
  // app-facing `tsc --noEmit` gate, so keep them out of the app typecheck.
  "exclude": ["test"]
}
